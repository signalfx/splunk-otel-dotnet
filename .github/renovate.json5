{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:best-practices",
  ],
  enabledManagers: [
    "github-actions",
    "nuget",
  ],
  prConcurrentLimit: 20,
  nuget: {
    managerFilePatterns: [
      // Default values from: https://docs.renovatebot.com/modules/manager/nuget/#default-config
      "/\\.(?:cs|fs|vb)proj$/",
      "/\\.(?:props|targets)$/",
      "/(^|/)dotnet-tools\\.json$/",
      "/(^|/)global\\.json$/",

      // Additional files used in this repository.
      "/\\.slnx$/",
    ],
  },
}
