{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  additionalBranchPrefix: "{{manager}}/",
  labels: ["dependencies"],
  commitMessageAction: "Bump",
  extends: ["config:best-practices"],
  customManagers: [
    {
      customType: "regex",
      description: "Update Debian arm64 package version ENVs in Dockerfiles",
      managerFilePatterns: ["/^docker\\/debian-arm64\\.dockerfile$/"],
      matchStrings: [
        "#\\s*renovate:\\s*(?:suite=(?<suite>\\S+)\\s+)?depName=(?<depName>\\S+)\\s*\\n\\s*ENV\\s+.*?_VERSION=\"(?<currentValue>[^\"]+)\"",
      ],
      registryUrlTemplate: "https://deb.debian.org/debian?suite={{#if suite}}{{suite}}{{else}}bookworm{{/if}}&components=main&binaryArch=arm64",
      datasourceTemplate: "deb",
    },
    {
      customType: "regex",
      description: "Update Alpine package version ENVs in Dockerfiles",
      managerFilePatterns: ["/^docker\\/alpine-(x64|arm64)\\.dockerfile$/"],
      matchStrings: [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\n\\s*ENV\\s+.*?_VERSION=\"(?<currentValue>[^\"]+)\"",
      ],
      packageNameTemplate: "alpine_3_23/{{{depName}}}",
      versioningTemplate: "apk",
    },
    {
      customType: "regex",
      description: "Update .NET SDK versions used by CI and build containers",
      managerFilePatterns: [
        "/^\\.github\\/workflows\\/(ci|dotnet-format|scripts-test)\\.yml$/",
        "/^\\.gitlab-ci\\.yml$/",
        "/^docker\\/(alpine-(x64|arm64)|debian-arm64)\\.dockerfile$/",
      ],
      matchStrings: [
        "dotnet-version:[ \\t]+(?<currentValue>(?<sdkMajor>\\d+)\\.\\d+\\.\\d+)",
        "(?:^|\\r?\\n)[ \\t]+(?<currentValue>(?<sdkMajor>\\d+)\\.\\d+\\.\\d+)[ \\t]*",
        "dotnet\\/sdk:(?<currentValue>(?<sdkMajor>\\d+)\\.\\d+\\.\\d+)-noble",
        "dotnet-install\\.sh -v (?<currentValue>(?<sdkMajor>\\d+)\\.\\d+\\.\\d+)",
      ],
      depNameTemplate: ".NET SDK {{{sdkMajor}}}",
      packageNameTemplate: "dotnet-sdk",
      datasourceTemplate: "dotnet-version",
      versioningTemplate: "semver",
    },
  ],
  packageRules: [
    {
      description: "Group .NET SDK updates and keep each SDK on its current major",
      matchDatasources: ["dotnet-version"],
      matchPackageNames: ["dotnet-sdk"],
      allowedVersions: "<{{add major 1}}",
      groupName: ".NET SDKs",
    },
  ],
  prConcurrentLimit: 20,
}
