{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "github-actions",
    "nuget"
  ],
  "prConcurrentLimit": 20,
  "nuget": {
    "managerFilePatterns": [
      "/(^|/)packages\\.config$/",
      "/(^|/)global\\.json$/",
      "/\\.slnx$/",
      "/\\.(?:cs|fs|vb)proj$/",
      "/\\.props$/",
      "/\\.targets$/"
    ]
  }
}
